// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  username         String   @unique
  email            String   @unique
  password         String
  role             String   @default("USER") // GUEST, USER, AGENT, ADMIN
  balance          Float    @default(0)
  avatarUrl        String   @default("https://picsum.photos/seed/avatar/200/200")
  subscriptionTier String   @default("Free") // Free, Pro, Elite
  emailVerified    Boolean  @default(false)
  emailVerificationCode      String?
  emailVerificationExpiresAt DateTime?
  fullName         String?
  address          String?
  phone            String?
  paymentMethod    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
  payments         Payment[]
  loyaltyPoints    LoyaltyPoint[]
  cart             Cart?
}

model Sequence {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Category {
  id            String        @id @default(uuid())
  name          String
  slug          String        @unique
  icon          String
  imageUrl      String?
  gradient      String?
  description   String?
  subCategories SubCategory[]
  listings      Listing[]
}

model SubCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  icon        String?
  description String?
  order       Int       @default(0)
  listings    Listing[]
}

model Listing {
  id                String       @id @default(uuid())
  title             String
  description       String
  price             Float
  isArchived        Boolean      @default(false)
  discountPercent   Int          @default(0)
  discountType      String       @default("NONE")
  discountValue     Float        @default(0)
  categoryId        String
  category          Category     @relation(fields: [categoryId], references: [id])
  subCategoryId     String?
  subCategory       SubCategory? @relation(fields: [subCategoryId], references: [id])
  logoUrl           String?
  imageUrl          String
  gallery           String       @default("[]") // JSON string array
  game              String?
  stock             Int          @default(1)
  deliveryTimeHours Int          @default(24)
  isInstant         Boolean      @default(true)
  preparationTime   String?      // e.g., "2-3 jours", "Immédiat"
  salesCount        Int          @default(0)
  metaTitle         String?
  metaDesc          String?
  keywords          String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  cartItems         CartItem[]
  orderItems        OrderItem[]
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique
  userId              String?
  user                User?       @relation(fields: [userId], references: [id])
  status              String      @default("REGISTERED")
  amount              Float
  currency            String      @default("TND")
  source              String      @default("GUEST")
  customerFirstName   String
  customerLastName    String
  customerEmail       String
  customerPhone       String
  paymentMethod       String?
  paymentConfirmedAt  DateTime?
  emailStatus         String      @default("PENDING")
  emailSentAt         DateTime?
  emailError          String?
  items               OrderItem[]
  invoice             Invoice?
  payments            Payment[]
  loyaltyPoints       LoyaltyPoint[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model OrderItem {
  id            String        @id @default(uuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId     String
  listing       Listing       @relation(fields: [listingId], references: [id])
  quantity      Int
  priceSnapshot Float
  titleSnapshot String
  invoiceItems  InvoiceItem[]
}

model Invoice {
  id                String        @id @default(uuid())
  invoiceNumber     String        @unique
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type              String        @default("PROFORMA")
  status            String        @default("PENDING_PAYMENT")
  currency          String        @default("TND")
  orderNumber       String
  customerFirstName String
  customerLastName  String
  customerEmail     String
  customerPhone     String
  totalAmount       Float
  issueDate         DateTime      @default(now())
  emailSentAt       DateTime?
  emailError        String?
  items             InvoiceItem[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model InvoiceItem {
  id            String    @id @default(uuid())
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderItemId   String?
  orderItem     OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  listingId     String?
  quantity      Int
  unitPrice     Float
  lineTotal     Float
  titleSnapshot String
}

model DailyStat {
  id        String   @id @default(uuid())
  date      DateTime @unique
  sales     Float    @default(0)
  orders    Int      @default(0)
  newUsers  Int      @default(0)
  createdAt DateTime @default(now())
}

model Payment {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  method          String
  status          String   @default("PENDING")
  amount          Float
  currency        String   @default("TND")
  transactionRef  String?  @unique
  recordedBy      String?
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LoyaltyPoint {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  points      Int
  type        String   @default("EARNED")
  description String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
